<!DOCTYPE html>
<html>
<head>

<title>Instagram Analytics Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>

body{
font-family:Arial;
background:#111;
color:white;
text-align:center;
padding:30px;
}

h1{
color:#E1306C;
}

.container{
background:#1e1e1e;
padding:25px;
border-radius:10px;
width:420px;
margin:auto;
box-shadow:0 0 15px rgba(0,0,0,0.5);
}

input{
padding:10px;
width:90%;
margin:6px;
border-radius:6px;
border:none;
}

button{
background:#E1306C;
color:white;
padding:10px 20px;
border:none;
border-radius:6px;
cursor:pointer;
margin-top:10px;
}

button:hover{
background:#c1275c;
}

.stats{
margin-top:15px;
}

canvas{
margin-top:40px;
background:white;
border-radius:10px;
padding:10px;
}

</style>

</head>

<body>

<h1>Instagram Analytics Dashboard</h1>

<div class="container">

<input id="username" placeholder="Instagram Username">

<input id="followers" type="number" placeholder="Followers">

<input id="likes" type="number" placeholder="Average Likes">

<input id="comments" type="number" placeholder="Average Comments">

<button onclick="saveStats()">Save Today Stats</button>

<div class="stats">

<p id="engagement"></p>
<p id="growth"></p>

</div>

</div>

<canvas id="chart" width="600" height="300"></canvas>

<script>

let followersData = JSON.parse(localStorage.getItem("followersData")) || [];
let dates = JSON.parse(localStorage.getItem("dates")) || [];

function saveStats(){

let followers = parseInt(document.getElementById("followers").value);
let likes = parseInt(document.getElementById("likes").value);
let comments = parseInt(document.getElementById("comments").value);

let date = new Date().toLocaleDateString();

followersData.push(followers);
dates.push(date);

localStorage.setItem("followersData",JSON.stringify(followersData));
localStorage.setItem("dates",JSON.stringify(dates));

let engagement=((likes+comments)/followers*100).toFixed(2);

document.getElementById("engagement").innerHTML =
"Engagement Rate: "+engagement+"%";

let growth=0;

if(followersData.length>1){
growth=followersData[followersData.length-1]-followersData[followersData.length-2];
}

document.getElementById("growth").innerHTML =
"Follower Growth Today: "+growth;

drawChart();

}

function drawChart(){

let ctx=document.getElementById("chart").getContext("2d");

new Chart(ctx,{
type:"line",
data:{
labels:dates,
datasets:[{
label:"Follower Growth",
data:followersData,
borderWidth:3
}]
}
});

}

drawChart();

</script>

</body>

</html>
