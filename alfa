<!DOCTYPE html>
<html>
<head>
<title>Instagram Profile Tracker</title>
<style>
body{
font-family: Arial;
background:#f5f5f5;
text-align:center;
padding:40px;
}

.card{
background:white;
padding:30px;
border-radius:10px;
width:350px;
margin:auto;
box-shadow:0 0 10px rgba(0,0,0,0.1);
}

input{
padding:10px;
width:80%;
margin:10px;
}

button{
padding:10px 20px;
background:#e1306c;
color:white;
border:none;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#c72b60;
}

.stats{
margin-top:20px;
}
</style>
</head>

<body>

<div class="card">

<h2>Instagram Profile Tracker</h2>

<input id="username" placeholder="Enter Instagram username">

<br>

<input id="followers" placeholder="Current followers">

<br>

<button onclick="saveData()">Save Today Stats</button>

<div class="stats">
<h3>Saved Data</h3>
<p id="output"></p>
</div>

</div>

<script>

function saveData(){

let user = document.getElementById("username").value;
let followers = document.getElementById("followers").value;

let today = new Date().toLocaleDateString();

let data = today + " - @" + user + " : " + followers + " followers";

localStorage.setItem("instaStats", data);

document.getElementById("output").innerHTML = data;

}

document.getElementById("output").innerHTML =
localStorage.getItem("instaStats");

</script>

</body>
</html>
